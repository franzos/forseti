# Autorización de dispositivo (RFC 8628): pantallas de verificación y finalización

device-verify-page-title = Aprobar inicio de sesión de Linux
device-verify-card-title = Aprobar un inicio de sesión de Linux
device-verify-prompt = ¿Acaba de iniciar este inicio de sesión?
device-verify-host = Inicio de sesión de Linux como { $user } en el host { $host } (host { $hostid }).
device-verify-warning = Apruebe solo si lo inició en esa máquina. Si no fue usted, cierre esta página. Aprobar permite que quien lo haya iniciado inicie sesión como { $user }.
device-verify-approve = Sí, fui yo, continuar
device-verify-cancel = No, cancelar
device-verify-code-prompt = Introduzca el código que aparece en su terminal para continuar.
device-verify-code-submit = Continuar

device-done-title-error = Inicio de sesión no aprobado
device-done-title-ok = Inicio de sesión aprobado
device-done-card-title-error = No pudimos aprobar ese inicio de sesión
device-done-card-title-ok = Aprobado
device-done-body-error = Es posible que ese código haya expirado o ya se haya usado. Inicie sesión de nuevo en su terminal para obtener un código nuevo.
device-done-body-ok = Puede volver a su terminal, el inicio de sesión continuará allí.
device-done-body-safe = Puede cerrar esta página con seguridad.

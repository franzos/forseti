# Relative Zeitangaben (src/format.rs::humanise_timestamp).
# `{ $n }` ist der Betrag der Zeitspanne.
format-relative-just-now = gerade eben
format-relative-in-a-moment = gleich
format-relative-yesterday = gestern
format-relative-tomorrow = morgen
format-relative-minutes-ago = vor { $n } Min.
format-relative-minutes-in = in { $n } Min.
format-relative-hours-ago = vor { $n } Std.
format-relative-hours-in = in { $n } Std.
format-relative-days-ago = vor { $n } Tagen
format-relative-days-in = in { $n } Tagen
format-relative-months-ago = vor { $n } Mon.
format-relative-months-in = in { $n } Mon.
format-relative-years-ago = vor { $n } J.
format-relative-years-in = in { $n } J.

# User-Agent-Aufbereitung (src/format.rs::humanise_user_agent).
format-ua-on = { $browser } unter { $os }
format-ua-unknown-browser = Unbekannter Browser
format-ua-unknown-os = Unbekanntes System
format-device-unknown = Unbekanntes Gerät

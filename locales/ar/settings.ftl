# رسائل التنبيه ونصوص الأخطاء المضمّنة المضبوطة في معالجات Rust.
flash-session-signed-out = تم تسجيل الخروج من الجلسة.
flash-session-signout-failed = تعذّر تسجيل الخروج من تلك الجلسة.
flash-sessions-signed-out-others =
    { $count ->
        [zero] لم يتم تسجيل الخروج من أي جلسة أخرى.
        [one] تم تسجيل الخروج من جلسة أخرى واحدة.
        [two] تم تسجيل الخروج من جلستين أخريين.
        [few] تم تسجيل الخروج من { $count } جلسات أخرى.
        [many] تم تسجيل الخروج من { $count } جلسة أخرى.
       *[other] تم تسجيل الخروج من { $count } جلسة أخرى.
    }
flash-sessions-signout-others-failed = تعذّر تسجيل الخروج من الجلسات الأخرى.
flash-app-access-revoked = تم إلغاء الوصول.
flash-app-access-revoke-failed = تعذّر إلغاء وصول ذلك التطبيق.
flash-offline-passphrase-saved = تم حفظ عبارة المرور دون اتصال. ستلتقطها المضيفات المُسجَّلة عند مزامنتها التالية.
flash-offline-passphrase-save-failed = تعذّر حفظ عبارة مرورك دون اتصال. يُرجى المحاولة مرة أخرى.
flash-offline-passphrase-too-short = يجب أن تكون عبارة مرورك دون اتصال { $min_len } حرفًا على الأقل.
flash-offline-passphrase-removed = تمت إزالة عبارة المرور دون اتصال. ستُسقطها المضيفات عند مزامنتها التالية.
flash-offline-passphrase-none = ليس لديك عبارة مرور دون اتصال مُعيّنة.
flash-offline-passphrase-remove-failed = تعذّر إزالة عبارة مرورك دون اتصال. يُرجى المحاولة مرة أخرى.
settings-profile-url-invalid = يجب أن يكون رابط الموقع الإلكتروني ورابط الصورة الرمزية عنواني http:// أو https:// صالحين.
settings-profile-link-url-invalid = يجب أن يكون كل رابط عنوان http:// أو https:// صالحًا.
settings-save-failed = تعذّر علينا حفظ تغييراتك. يُرجى المحاولة مرة أخرى.

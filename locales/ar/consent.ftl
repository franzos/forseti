consent-scope-email = عنوان بريدك الإلكتروني
consent-scope-offline_access = البقاء مسجّلًا للدخول عندما لا تستخدم التطبيق فعليًا
consent-scope-address = عنوانك البريدي
consent-scope-phone = رقم هاتفك
consent-scope-groups = عضوياتك في الفِرَق (تُستخدَم لتعيين الأدوار في التطبيق المتصل)
consent-scope-org = مؤسستك ودورك النشطان
consent-scope-orgs = مؤسساتك وأدوارك

consent-card-title = تفويض { $app }
